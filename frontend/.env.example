# URL base do backend FastAPI (todas as chamadas de api.js passam por aqui).
VITE_API_URL=http://localhost:8000

# Supabase — usado só para upload de fotos no Storage (não é o login).
# Pegue estes valores em Project Settings > API no painel do Supabase.
VITE_SUPABASE_URL=https://[SEU-PROJETO].supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
